<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} optica-product-breadcrumbs color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
  {{ section.shopify_attributes }}
>
  <div class="optica-product-breadcrumbs__inner">
    {% render 'optica-breadcrumbs', product: product %}
  </div>
</div>

{% stylesheet %}
  .optica-product-breadcrumbs__inner {
    display: flex;
    justify-content: flex-start;
    text-align: left;
  }

  .optica-breadcrumbs-section .section-background {
    background: rgba(20,18,16,0.95);
  }

  .optica-breadcrumbs-section {
    border-block-end: 1px solid rgba(201,169,110,0.18);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "OPTICA breadcrumbs",
  "tag": "section",
  "class": "optica-breadcrumbs-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "OPTICA breadcrumbs",
      "category": "t:categories.products",
      "settings": {
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 12,
        "padding-block-end": 12
      }
    }
  ]
}
{% endschema %}
