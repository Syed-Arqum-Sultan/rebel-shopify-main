<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <h2 class="atelier-trust__title">{{ section.settings.heading | escape }}</h2>
  {% endif %}
  <ul class="atelier-trust__grid">
    {% for block in section.blocks %}
      <li class="atelier-trust__item" {{ block.shopify_attributes }}>
        <div class="atelier-trust__icon" aria-hidden="true">
          {% case block.settings.icon %}
            {% when 'uv' %}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                <path d="M8 14c1.5-2 2.5-4 4-4s2.5 2 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            {% when 'swiss' %}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="7" width="16" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M12 9v6M9 12h6" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            {% when 'shipping' %}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 10h11v8H3v-8zM14 12h4l3 3v3h-7v-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <circle cx="7.5" cy="20" r="1.5" fill="currentColor"/>
                <circle cx="18.5" cy="20" r="1.5" fill="currentColor"/>
              </svg>
            {% when 'warranty' %}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3l8 3v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M9 12l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {% else %}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
              </svg>
          {% endcase %}
        </div>
        <h3 class="atelier-trust__item-title">{{ block.settings.title | escape }}</h3>
        {% if block.settings.text != blank %}
          <p class="atelier-trust__item-text">{{ block.settings.text | escape }}</p>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</div>

{% stylesheet %}
  .atelier-trust__title {
    text-align: center;
    margin: 0 0 var(--padding-2xl);
    font-family: var(--font-heading--family);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .atelier-trust__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;

    @media screen and (min-width: 750px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media screen and (min-width: 990px) {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }

  .atelier-trust__item {
    text-align: center;
    padding: var(--padding-lg);
    border: 1px solid rgba(201,169,110,0.18);
    border-radius: 0;
    background: rgba(39,35,32,0.5);
  }

  .atelier-trust__icon {
    color: var(--color-primary);
    margin: 0 auto var(--padding-md);
    display: flex;
    justify-content: center;
  }

  .atelier-trust__item-title {
    margin: 0 0 var(--padding-xs);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .atelier-trust__item-text {
    margin: 0;
    font-size: 11px;
    line-height: 1.6;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Atelier trust features",
  "tag": "section",
  "class": "atelier-trust-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why choose us"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "uv", "label": "UV / protection" },
            { "value": "swiss", "label": "Precision / movement" },
            { "value": "shipping", "label": "Shipping" },
            { "value": "warranty", "label": "Warranty / shield" }
          ],
          "default": "uv"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "UV protection"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Premium lens coatings that filter harmful rays."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Atelier trust features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "uv",
            "title": "UV protection",
            "text": "Lenses rated to help shield your eyes outdoors."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "swiss",
            "title": "Swiss movement",
            "text": "Timepieces powered by precision Swiss calibres."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "shipping",
            "title": "Complimentary shipping",
            "text": "Tracked delivery on qualifying orders worldwide."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "warranty",
            "title": "2-year warranty",
            "text": "Manufacturer-backed care on eligible pieces."
          }
        }
      ]
    }
  ]
}
{% endschema %}
