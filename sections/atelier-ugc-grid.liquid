<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <h2 class="atelier-ugc__title">{{ section.settings.heading | escape }}</h2>
  {% endif %}
  {% if section.settings.subheading != blank %}
    <p class="atelier-ugc__sub">{{ section.settings.subheading | escape }}</p>
  {% endif %}

  <ul class="atelier-ugc__grid">
    {% for block in section.blocks %}
      <li class="atelier-ugc__cell" {{ block.shopify_attributes }}>
        {% if block.settings.link != blank %}
          <a class="atelier-ugc__link" href="{{ block.settings.link }}" target="_blank" rel="noopener noreferrer">
        {% else %}
          <div class="atelier-ugc__link atelier-ugc__link--static">
        {% endif %}
        <div class="atelier-ugc__media">
          {% if block.settings.image != blank %}
            {% liquid
              assign ugc_alt = block.settings.image.alt | default: section.settings.heading
            %}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 990px) 16vw, 50vw',
                widths: '200, 300, 400, 600, 800',
                alt: ugc_alt
            }}
          {% else %}
            <div class="atelier-ugc__placeholder"></div>
          {% endif %}
        </div>
        {% if block.settings.link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</div>

{% stylesheet %}
  .atelier-ugc__title {
    text-align: center;
    margin: 0 0 var(--padding-sm);
    font-family: var(--font-heading--family);
    font-size: clamp(1.5rem, 3.5vw, var(--font-h3--size));
  }

  .atelier-ugc__sub {
    text-align: center;
    margin: 0 auto var(--padding-2xl);
    max-width: 36rem;
    opacity: 0.85;
    font-size: 1rem;
  }

  .atelier-ugc__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;

    @media screen and (min-width: 750px) {
      grid-template-columns: repeat(3, 1fr);
    }

    @media screen and (min-width: 990px) {
      grid-template-columns: repeat(6, 1fr);
      gap: 6px;
    }
  }

  .atelier-ugc__link {
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    aspect-ratio: 1;
    border-radius: 2px;
  }

  .atelier-ugc__link--static {
    cursor: default;
  }

  .atelier-ugc__media {
    width: 100%;
    height: 100%;
  }

  .atelier-ugc__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .atelier-ugc__link:hover .atelier-ugc__media img {
      transform: scale(1.04);
    }
  }

  .atelier-ugc__placeholder {
    width: 100%;
    height: 100%;
    background: rgb(var(--color-foreground-rgb) / 0.07);
    min-height: 6rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Atelier UGC grid",
  "tag": "section",
  "class": "atelier-ugc-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From our community"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tag us @youratelier for a chance to be featured."
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "full-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)",
          "info": "e.g. Instagram post"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Atelier UGC grid",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
