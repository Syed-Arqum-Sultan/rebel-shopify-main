<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <h2 class="atelier-cat__section-title">{{ section.settings.heading | escape }}</h2>
  {% endif %}
  <ul class="atelier-cat__grid">
    {% for block in section.blocks %}
      <li
        class="atelier-cat__tile"
        {{ block.shopify_attributes }}
      >
        <a
          class="atelier-cat__link"
          href="{{ block.settings.link | default: '#' }}"
          {% if block.settings.link == blank %}
            role="link" aria-disabled="true"
          {% endif %}
        >
          <div class="atelier-cat__media">
            {% if block.settings.image != blank %}
              {% liquid
                assign tile_alt = block.settings.image.alt | default: block.settings.title
              %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 33vw, 100vw',
                  widths: '400, 600, 800, 1000, 1200',
                  alt: tile_alt
              }}
            {% else %}
              <div class="atelier-cat__placeholder"></div>
            {% endif %}
          </div>
          <div class="atelier-cat__overlay">
            <span class="atelier-cat__label">{{ block.settings.title | escape }}</span>
            {% if block.settings.subtitle != blank %}
              <span class="atelier-cat__subtitle">{{ block.settings.subtitle | escape }}</span>
            {% endif %}
          </div>
        </a>
      </li>
    {% endfor %}
  </ul>
</div>

{% stylesheet %}
  .atelier-cat__section-title {
    text-align: center;
    margin: 0 0 var(--padding-2xl);
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 4vw, var(--font-h2--size));
  }

  .atelier-cat__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--padding-md);

    @media screen and (min-width: 750px) {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--padding-lg);
    }
  }

  .atelier-cat__link {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .atelier-cat__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--style-border-radius-cards);
    background: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .atelier-cat__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transition: transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  @media (prefers-reduced-motion: no-preference) {
    .atelier-cat__link:hover .atelier-cat__media img,
    .atelier-cat__link:focus-visible .atelier-cat__media img {
      transform: scale(1.06);
    }
  }

  .atelier-cat__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      145deg,
      rgb(var(--color-foreground-rgb) / 0.08),
      rgb(var(--color-foreground-rgb) / 0.02)
    );
  }

  .atelier-cat__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: var(--padding-lg) var(--padding-md);
    background: linear-gradient(to top, rgb(var(--color-background-rgb, 0 0 0) / 0.7) 0%, transparent 50%);
    z-index: 1;
    pointer-events: none;
  }

  .atelier-cat__label {
    display: block;
    text-align: center;
    font-family: var(--font-heading--family);
    font-size: var(--font-h5--size);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  .atelier-cat__subtitle {
    display: block;
    margin-top: 4px;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Atelier category tiles",
  "tag": "section",
  "class": "atelier-category-tiles-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Eyeglasses"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "info": "Optional text shown below the category title on the tile overlay."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Atelier category tiles",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Eyeglasses"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Sunglasses"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Watches"
          }
        }
      ]
    }
  ]
}
{% endschema %}
