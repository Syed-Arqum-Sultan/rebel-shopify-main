<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style optica-about"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- comment -%} Hero banner {%- endcomment -%}
  <div class="optica-about__hero">
    {% if section.settings.heading != blank %}
      <h1 class="optica-about__heading">{{ section.settings.heading | escape }}</h1>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <p class="optica-about__sub">{{ section.settings.subtext | escape }}</p>
    {% endif %}
  </div>

  {%- comment -%} Our Story {%- endcomment -%}
  {% if section.settings.story_heading != blank or section.settings.story_body != blank %}
    <div class="optica-about__story">
      {% if section.settings.story_heading != blank %}
        <h2 class="optica-about__story-heading">{{ section.settings.story_heading | escape }}</h2>
      {% endif %}
      {% if section.settings.story_body != blank %}
        <div class="optica-about__story-body rte">{{ section.settings.story_body }}</div>
      {% endif %}
    </div>
  {% endif %}

  {%- comment -%} Values grid {%- endcomment -%}
  {% if section.blocks.size > 0 %}
    {% if section.settings.values_heading != blank %}
      <h2 class="optica-about__values-heading">{{ section.settings.values_heading | escape }}</h2>
    {% endif %}
    <ul class="optica-about__values">
      {% for block in section.blocks %}
        <li class="optica-about__value" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="optica-about__value-icon">{{ block.settings.icon }}</div>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="optica-about__value-title">{{ block.settings.title | escape }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="optica-about__value-text">{{ block.settings.text | escape }}</p>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  {%- comment -%} Brand statement {%- endcomment -%}
  {% if section.settings.statement != blank %}
    <div class="optica-about__statement">
      <blockquote class="optica-about__quote">{{ section.settings.statement | escape }}</blockquote>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .optica-about__hero {
    text-align: center;
    max-width: 48rem;
    margin: 0 auto var(--padding-2xl);
  }

  .optica-about__heading {
    margin: 0 0 var(--padding-md);
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .optica-about__sub {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.65;
    opacity: 0.8;
  }

  .optica-about__story {
    max-width: 42rem;
    margin: 0 auto var(--padding-2xl);
    text-align: center;
  }

  .optica-about__story-heading {
    margin: 0 0 var(--padding-md);
    font-family: var(--font-heading--family);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .optica-about__story-body {
    font-size: 0.95rem;
    line-height: 1.75;
    opacity: 0.75;
  }

  .optica-about__values-heading {
    text-align: center;
    margin: 0 0 var(--padding-xl);
    font-family: var(--font-heading--family);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .optica-about__values {
    list-style: none;
    margin: 0 0 var(--padding-2xl);
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--padding-lg);
    max-width: 64rem;
    margin-inline: auto;

    @media screen and (min-width: 750px) {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }

  .optica-about__value {
    text-align: center;
    padding: var(--padding-xl);
    border: 1px solid rgb(var(--color-primary-rgb) / 0.15);
    border-radius: var(--style-border-radius-cards);
    background: rgb(var(--color-foreground-rgb) / 0.03);
  }

  .optica-about__value-icon {
    margin-bottom: var(--padding-md);
    font-size: 1.5rem;
    color: var(--color-primary);
  }

  .optica-about__value-title {
    margin: 0 0 8px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .optica-about__value-text {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.6;
    opacity: 0.65;
  }

  .optica-about__statement {
    max-width: 42rem;
    margin: 0 auto;
    text-align: center;
    border-top: 1px solid rgb(var(--color-primary-rgb) / 0.18);
    padding-top: var(--padding-2xl);
  }

  .optica-about__quote {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-style: italic;
    line-height: 1.5;
    opacity: 0.8;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "OPTICA about",
  "tag": "section",
  "class": "optica-about-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About OPTICA"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "We believe eyewear and timepieces are more than accessories — they're an expression of identity, precision, and craftsmanship."
    },
    {
      "type": "text",
      "id": "story_heading",
      "label": "Story heading",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "story_body",
      "label": "Story content",
      "default": "<p>Founded with a simple conviction: everyone deserves access to exquisitely crafted eyewear and timepieces without the traditional luxury markup. We partner directly with heritage ateliers across Italy, Japan, and Switzerland to bring you pieces that rival any maison — at a fraction of the price.</p><p>Every frame is hand-finished, every movement Swiss-certified, and every interaction backed by our concierge team who treat your order like their own.</p>"
    },
    {
      "type": "text",
      "id": "values_heading",
      "label": "Values section heading",
      "default": "What We Stand For"
    },
    {
      "type": "textarea",
      "id": "statement",
      "label": "Brand statement",
      "default": "Precision in every detail. Integrity in every interaction. Beauty in every piece."
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or text)",
          "default": "◆"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Heritage Craft"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Every piece is hand-finished by artisans with decades of expertise in their craft."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "OPTICA about",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "icon": "◆",
            "title": "Heritage Craft",
            "text": "Every piece is hand-finished by artisans with decades of expertise in their craft."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "⟡",
            "title": "Direct Partnership",
            "text": "We work directly with ateliers — no middlemen, no inflated pricing, just honest luxury."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "◎",
            "title": "Optical Precision",
            "text": "UV400 lenses, Swiss movements, and rigorous quality checks on every single piece."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "♛",
            "title": "Concierge Service",
            "text": "Our team treats every order with the care and attention of a private fitting."
          }
        }
      ]
    }
  ]
}
{% endschema %}
