{%- liquid
  assign bs = block.settings
  assign product_form_id = 'BuyButtons-ProductForm-' | append: section.id
  assign method_name = bs.method_property_key | default: 'Prescription method'
  assign status_name = bs.status_property_key | default: 'Prescription status'
  assign upload_property_name = bs.upload_property_key | default: 'Prescription file'
  assign enable_metafield = closest.product.metafields.custom.enable_prescription
-%}
{% assign is_enabled_for_product = enable_metafield.value %}
{% if is_enabled_for_product == blank %}
  {% assign is_enabled_for_product = false %}
{% endif %}
{% if bs.disable_metafield_gate %}
  {% assign is_enabled_for_product = true %}
{% endif %}
{% assign show_in_editor_debug = false %}
{% if request.design_mode and is_enabled_for_product == false %}
  {% assign show_in_editor_debug = true %}
{% endif %}
{% if is_enabled_for_product or show_in_editor_debug %}
  {% capture rx_missing_default %}
    {%- if bs.enable_send_later -%}
      Add a file, type your Rx below, or check send later.
    {%- else -%}
      Add a file or type your Rx below.
    {%- endif -%}
  {% endcapture %}
  {% assign rx_missing_raw = bs.rx_missing_method_message | strip %}
  {% if rx_missing_raw == blank or rx_missing_raw == '__atelier_rx_missing_auto__' %}
    {% assign rx_missing_message = rx_missing_default | strip %}
  {% else %}
    {% assign rx_missing_message = rx_missing_raw %}
  {% endif %}
  <div
    class="atelier-prescription-input spacing-style{% unless bs.inherit_color_scheme %} color-{{ bs.color_scheme }}{% endunless %}"
    style="{% render 'spacing-style', settings: bs %}"
    data-atelier-rx-root
    data-product-form-id="{{ product_form_id }}"
    {{ block.shopify_attributes }}
  >
    <input
      type="hidden"
      form="{{ product_form_id }}"
      name="properties[{{ method_name | strip | replace: '"', '' }}]"
      value=""
      data-rx-method
    >

    <input
      type="hidden"
      form="{{ product_form_id }}"
      name="properties[{{ status_name | strip | replace: '"', '' }}]"
      value="Not required"
      data-rx-status
    >

    <div class="atelier-prescription-input__panel" data-rx-content hidden>
      {% if bs.heading != blank %}
        <p class="atelier-prescription-input__label" id="rx-heading-{{ block.id }}">{{ bs.heading | escape }}</p>
      {% endif %}
      {% if bs.description != blank %}
        <p class="atelier-prescription-input__hint" id="rx-intro-{{ block.id }}">{{ bs.description | escape }}</p>
      {% endif %}

      <p class="atelier-prescription-input__missing" data-rx-missing-warning hidden role="status">
        {{ rx_missing_message | escape }}
      </p>

      <div class="atelier-prescription-input__primary" data-rx-upload-section>
        <div class="atelier-prescription-input__file-row">
          <input
            id="rx-file-{{ block.id }}"
            class="visually-hidden"
            type="file"
            form="{{ product_form_id }}"
            name="properties[{{ upload_property_name | strip | replace: '"', '' }}]"
            accept=".jpg,.jpeg,.png,.pdf"
            data-rx-file
            {% liquid
              assign rx_aria = ''
              if bs.upload_helper_text != blank
                assign rx_aria = 'rx-file-hint-' | append: block.id
              endif
              if bs.description != blank
                if rx_aria != blank
                  assign rx_aria = rx_aria | append: ' '
                endif
                assign rx_aria = rx_aria | append: 'rx-intro-' | append: block.id
              endif
              if bs.heading != blank
                if rx_aria != blank
                  assign rx_aria = rx_aria | append: ' '
                endif
                assign rx_aria = rx_aria | append: 'rx-heading-' | append: block.id
              endif
            %}
            {% if rx_aria != blank %}
              aria-describedby="{{ rx_aria | strip }}"
            {% endif %}
          >
          <label class="atelier-prescription-input__file-btn" for="rx-file-{{ block.id }}">{{ bs.upload_label | escape }}</label>
          <span class="atelier-prescription-input__file-name" data-rx-file-name></span>
        </div>
        {% if bs.upload_helper_text != blank %}
          <p class="atelier-prescription-input__micro" id="rx-file-hint-{{ block.id }}">{{ bs.upload_helper_text | escape }}</p>
        {% endif %}
      </div>

      {% if bs.enable_send_later %}
        <label class="atelier-prescription-input__send-later">
          <input type="checkbox" form="{{ product_form_id }}" data-rx-send-later>
          <span>{{ bs.send_later_label | escape }}</span>
        </label>
        {% if bs.send_later_helper != blank %}
          <p class="atelier-prescription-input__micro" data-rx-send-later-note hidden>{{ bs.send_later_helper | escape }}</p>
        {% endif %}
      {% endif %}

      <details class="atelier-prescription-input__manual-details" data-rx-manual-details>
        <summary class="atelier-prescription-input__manual-summary">
          {{- bs.manual_entry_label | default: 'Type prescription manually' | escape -}}
        </summary>
        <div class="atelier-prescription-input__fields" data-rx-fields>
          <div class="atelier-prescription-input__row atelier-prescription-input__row--head">
            <span></span>
            <span>SPH</span>
            <span>CYL</span>
            <span>AXIS</span>
            <span>ADD</span>
          </div>

          {% assign eyes = 'OD,OS' | split: ',' %}
          {% for eye in eyes %}
            <div class="atelier-prescription-input__row">
              <span class="atelier-prescription-input__eye">{{ eye }}</span>
              <label>
                <span class="visually-hidden">{{ eye }} SPH</span>
                <input type="text" inputmode="decimal" form="{{ product_form_id }}" name="properties[{{ eye }} SPH]" pattern="^-?\d{0,2}(\.\d{0,2})?$" placeholder="+/-0.00" data-rx-manual-field>
              </label>
              <label>
                <span class="visually-hidden">{{ eye }} CYL</span>
                <input type="text" inputmode="decimal" form="{{ product_form_id }}" name="properties[{{ eye }} CYL]" pattern="^-?\d{0,2}(\.\d{0,2})?$" placeholder="+/-0.00" data-rx-manual-field>
              </label>
              <label>
                <span class="visually-hidden">{{ eye }} AXIS</span>
                <input type="number" inputmode="numeric" min="1" max="180" form="{{ product_form_id }}" name="properties[{{ eye }} AXIS]" placeholder="1-180" data-rx-manual-field>
              </label>
              <label>
                <span class="visually-hidden">{{ eye }} ADD</span>
                <input type="text" inputmode="decimal" form="{{ product_form_id }}" name="properties[{{ eye }} ADD]" pattern="^\+?\d{0,2}(\.\d{0,2})?$" placeholder="+0.00" data-rx-manual-field>
              </label>
            </div>
          {% endfor %}

          <div class="atelier-prescription-input__pd">
            <label>
              <span>PD</span>
              <input
                type="text"
                inputmode="decimal"
                form="{{ product_form_id }}"
                name="properties[PD]"
                pattern="^\d{1,2}(\.\d{0,2})?$"
                placeholder="e.g. 63.0"
                data-rx-manual-field
              >
            </label>
          </div>
        </div>
      </details>
    </div>

    {% if show_in_editor_debug %}
      <div class="atelier-prescription-input__warning">
        Theme editor preview mode: this block is visible for setup.
        {% unless is_enabled_for_product %}
          Turn on product metafield `custom.enable_prescription` to show it live.
        {% endunless %}
      </div>
    {% endif %}
  </div>

  <script>
    (function () {
      // Script is a sibling *after* the root div (not nested inside it), so
      // `closest('[data-atelier-rx-root]')` is always null here. Use the root
      // element that immediately precedes this script.
      const root =
        document.currentScript?.previousElementSibling?.matches?.('[data-atelier-rx-root]')
          ? document.currentScript.previousElementSibling
          : document.currentScript?.closest?.('[data-atelier-rx-root]');
      if (!root) return;
      const formId = root.dataset.productFormId;
      const formIdEsc =
        typeof CSS !== 'undefined' && typeof CSS.escape === 'function'
          ? CSS.escape(formId)
          : String(formId).replace(/\\/g, '\\\\').replace(/"/g, '\\"');
      const form = document.getElementById(formId);
      if (!form) return;

      const rxContent = root.querySelector('[data-rx-content]');
      const missingWarning = root.querySelector('[data-rx-missing-warning]');
      const uploadSection = root.querySelector('[data-rx-upload-section]');
      const manualDetails = root.querySelector('[data-rx-manual-details]');
      const sendLaterNote = root.querySelector('[data-rx-send-later-note]');
      const fileNameEl = root.querySelector('[data-rx-file-name]');
      const methodInput = root.querySelector('[data-rx-method]');
      const statusInput = root.querySelector('[data-rx-status]');
      const sendLaterCheckbox = root.querySelector('[data-rx-send-later]');
      const fileInput = root.querySelector('[data-rx-file]');
      const manualFields = root.querySelectorAll('[data-rx-manual-field]');
      let rxRequired = false;

      function syncFileName() {
        if (!fileNameEl || !fileInput) return;
        const f = fileInput.files && fileInput.files[0];
        fileNameEl.textContent = f ? f.name : '';
      }

      function hasManualValues() {
        return Array.from(manualFields).some((field) => String(field.value || '').trim() !== '');
      }

      function setMissingWarning(show) {
        if (missingWarning) missingWarning.hidden = !show;
      }

      function getMethodAndStatus() {
        if (!rxRequired) return { method: '', status: 'Not required' };
        if (fileInput?.files && fileInput.files.length > 0) return { method: 'Uploaded file', status: 'Uploaded' };
        if (hasManualValues()) return { method: 'Manual entry', status: 'Manual entry' };
        if (sendLaterCheckbox?.checked) return { method: 'Send later', status: 'Send later' };
        return { method: '', status: 'Missing method' };
      }

      function resolveRxRequiredFromForm() {
        const hiddenRxField = document.querySelector(
          `[data-lens-requires-rx][form="${formIdEsc}"]`
        );
        if (hiddenRxField && (hiddenRxField.value == 'true' || hiddenRxField.value == 'false')) {
          return hiddenRxField.value == 'true';
        }

        const lensSelect = document.querySelector(
          `.atelier-lens-select__select[form="${formIdEsc}"]`
        );
        const lensOption = lensSelect?.selectedOptions?.[0];
        if (lensOption?.dataset?.requiresRx) {
          return lensOption.dataset.requiresRx == 'true';
        }
        return false;
      }

      function updateUi() {
        const sendLater = Boolean(sendLaterCheckbox?.checked);
        const methodAndStatus = getMethodAndStatus();

        root.hidden = !rxRequired;
        if (rxContent) rxContent.hidden = !rxRequired;
        if (uploadSection) uploadSection.hidden = sendLater;
        if (manualDetails) {
          manualDetails.hidden = sendLater;
          if (sendLater) manualDetails.open = false;
        }
        if (sendLaterNote) sendLaterNote.hidden = !sendLater;
        if (methodInput) methodInput.value = methodAndStatus.method;
        if (statusInput) statusInput.value = methodAndStatus.status;

        const missing = rxRequired && methodAndStatus.status == 'Missing method';
        setMissingWarning(missing);
        syncFileName();
        document.dispatchEvent(
          new CustomEvent('atelier:rx-warning', {
            bubbles: true,
            detail: { productFormId: formId, show: missing },
          })
        );
      }

      function validateField(field) {
        if (!field || field.disabled || field.offsetParent === null) return;
        if (field.validity.patternMismatch || field.validity.rangeOverflow || field.validity.rangeUnderflow) {
          field.setCustomValidity('Please use a valid prescription value.');
        } else {
          field.setCustomValidity('');
        }
      }

      sendLaterCheckbox?.addEventListener('change', updateUi);
      fileInput?.addEventListener('change', () => {
        syncFileName();
        updateUi();
      });
      manualFields.forEach((field) => {
        field.addEventListener('input', () => {
          validateField(field);
          updateUi();
        });
        field.addEventListener('blur', () => validateField(field));
      });

      document.addEventListener('atelier:lens-change', (event) => {
        if (event.detail?.productFormId !== formId) return;
        rxRequired = Boolean(event.detail?.lens?.requiresRx);
        if (!rxRequired) {
          setMissingWarning(false);
          if (manualDetails) manualDetails.open = false;
        }
        updateUi();
      });

      const externalLensSelect = document.querySelector(
        `.atelier-lens-select__select[form="${formIdEsc}"]`
      );
      externalLensSelect?.addEventListener('change', () => {
        rxRequired = resolveRxRequiredFromForm();
        if (!rxRequired && manualDetails) manualDetails.open = false;
        updateUi();
      });

      document.addEventListener('atelier:rx-warning', (event) => {
        if (event.detail?.productFormId !== formId) return;
        setMissingWarning(Boolean(event.detail?.show));
      });

      rxRequired = resolveRxRequiredFromForm();
      updateUi();
    })();
  </script>
{% endif %}

{% stylesheet %}
  .atelier-prescription-input {
    display: block;
  }

  .atelier-prescription-input__panel {
    display: grid;
    gap: 10px;
  }

  .atelier-prescription-input__label {
    margin: 0;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .atelier-prescription-input__hint {
    margin: 0;
    font-size: 11px;
    line-height: 1.55;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }

  .atelier-prescription-input__missing {
    margin: 0;
    font-size: 10px;
    line-height: 1.5;
    letter-spacing: 0.04em;
    color: rgb(var(--color-primary-rgb) / 0.95);
  }

  .atelier-prescription-input__primary {
    display: grid;
    gap: 6px;
  }

  .atelier-prescription-input__file-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }

  .atelier-prescription-input__file-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 10px 16px;
    border: 1px solid rgb(var(--color-primary-rgb) / 0.22);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .atelier-prescription-input__file-btn:hover {
    border-color: rgb(var(--color-primary-rgb) / 0.45);
  }

  .atelier-prescription-input__file-name {
    flex: 1;
    min-width: 0;
    font-size: 10px;
    letter-spacing: 0.04em;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .atelier-prescription-input__micro {
    margin: 0;
    font-size: 10px;
    line-height: 1.5;
    letter-spacing: 0.06em;
    color: rgb(var(--color-foreground-rgb) / 0.45);
  }

  .atelier-prescription-input__send-later {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 0;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .atelier-prescription-input__send-later input {
    margin-top: 2px;
    flex-shrink: 0;
  }

  .atelier-prescription-input__manual-details {
    border-block-start: 1px solid rgb(var(--color-primary-rgb) / 0.12);
    padding-block-start: 10px;
  }

  .atelier-prescription-input__manual-summary {
    list-style: none;
    cursor: pointer;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.75);
  }

  .atelier-prescription-input__manual-summary::-webkit-details-marker {
    display: none;
  }

  .atelier-prescription-input__manual-details[open] .atelier-prescription-input__manual-summary {
    margin-block-end: 10px;
    color: rgb(var(--color-foreground-rgb) / 0.95);
  }

  .atelier-prescription-input__fields {
    display: grid;
    gap: 8px;
    padding-block-start: 4px;
  }

  .atelier-prescription-input__row {
    display: grid;
    grid-template-columns: 44px repeat(4, minmax(0, 1fr));
    gap: 8px;
    align-items: center;
  }

  .atelier-prescription-input__row input {
    width: 100%;
    min-height: 40px;
    border-radius: 0;
  }

  .atelier-prescription-input__row--head span {
    font-size: 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .atelier-prescription-input__eye {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .atelier-prescription-input__pd label {
    display: grid;
    gap: 6px;
    max-width: 180px;
  }

  .atelier-prescription-input__pd span {
    font-size: 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  @media screen and (max-width: 749px) {
    .atelier-prescription-input__row {
      grid-template-columns: 32px 1fr 1fr;
    }

    .atelier-prescription-input__row--head {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Prescription input",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Prescription"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Short intro",
      "default": "Upload a clear photo of your Rx, type the values, or send it after you order."
    },
    {
      "type": "text",
      "id": "upload_label",
      "label": "Upload button label",
      "default": "Upload file"
    },
    {
      "type": "text",
      "id": "upload_property_key",
      "label": "Upload line item property key",
      "default": "Prescription file"
    },
    {
      "type": "text",
      "id": "upload_helper_text",
      "label": "File formats (small line under upload)",
      "default": "JPG, PNG, or PDF."
    },
    {
      "type": "text",
      "id": "manual_entry_label",
      "label": "Manual entry toggle label",
      "default": "Type prescription instead"
    },
    {
      "type": "checkbox",
      "id": "enable_send_later",
      "label": "Enable send-later option",
      "default": true
    },
    {
      "type": "text",
      "id": "send_later_label",
      "label": "Send-later checkbox label",
      "default": "I will send my prescription later"
    },
    {
      "type": "text",
      "id": "send_later_helper",
      "label": "Send-later note (shown when checked)",
      "default": "You can still check out. We will follow up for your Rx."
    },
    {
      "type": "text",
      "id": "rx_missing_method_message",
      "label": "Reminder when nothing is provided yet",
      "default": "__atelier_rx_missing_auto__",
      "info": "Keep the default token for automatic wording (matches send-later on/off). Replace with your own message anytime."
    },
    {
      "type": "header",
      "content": "Line item property keys"
    },
    {
      "type": "text",
      "id": "method_property_key",
      "label": "Prescription method property key",
      "default": "Prescription method"
    },
    {
      "type": "text",
      "id": "status_property_key",
      "label": "Prescription status property key",
      "default": "Prescription status"
    },
    {
      "type": "checkbox",
      "id": "disable_metafield_gate",
      "label": "Show even when product metafield is off (debug)",
      "default": false
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "Inherit color scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Prescription input"
    }
  ]
}
{% endschema %}
