{%- liquid
  assign bs = block.settings
  assign product_form_id = 'BuyButtons-ProductForm-' | append: section.id
  assign method_name = bs.method_property_key | default: 'Prescription method'
  assign status_name = bs.status_property_key | default: 'Prescription status'
  assign rx_lens_options = bs.rx_lens_options | downcase | newline_to_br | split: '<br />'
  assign lens_property_key = bs.lens_property_key | default: 'Lens type'
  assign enable_metafield = closest.product.metafields.custom.enable_prescription
-%}
{% capture atelier_hide_lens_frame_flag %}{% render 'atelier-pdp-hide-lens-frame', product: closest.product %}{% endcapture %}
{% assign atelier_hide_lens_frame_flag = atelier_hide_lens_frame_flag | strip %}
{% assign is_frame_context = atelier_hide_lens_frame_flag != '1' %}
{% assign is_enabled_for_product = enable_metafield.value %}
{% if is_enabled_for_product == blank %}
  {% assign is_enabled_for_product = false %}
{% endif %}
{% if bs.disable_metafield_gate %}
  {% assign is_enabled_for_product = true %}
{% endif %}
{% if is_frame_context and is_enabled_for_product %}
  <div
    class="atelier-prescription-input spacing-style{% unless bs.inherit_color_scheme %} color-{{ bs.color_scheme }}{% endunless %}"
    style="{% render 'spacing-style', settings: bs %}"
    data-atelier-rx-root
    data-lens-property-key="{{ lens_property_key | escape }}"
    data-rx-lens-options="{% for lens in rx_lens_options %}{% assign clean_lens = lens | strip %}{% if clean_lens != blank %}{{ clean_lens | escape }}{% unless forloop.last %}|{% endunless %}{% endif %}{% endfor %}"
    {{ block.shopify_attributes }}
  >
    {% if bs.heading != blank %}
      <p class="atelier-prescription-input__heading">{{ bs.heading | escape }}</p>
    {% endif %}
    {% if bs.description != blank %}
      <p class="atelier-prescription-input__description">{{ bs.description | escape }}</p>
    {% endif %}

    <div class="atelier-prescription-input__method">
      <label class="atelier-prescription-input__method-option">
        <input type="radio" name="properties[{{ method_name | strip | replace: '"', '' }}]" value="Manual entry" form="{{ product_form_id }}" checked>
        <span>{{ bs.manual_entry_label | escape }}</span>
      </label>
      {% if bs.enable_send_later %}
        <label class="atelier-prescription-input__method-option">
          <input type="radio" name="properties[{{ method_name | strip | replace: '"', '' }}]" value="Send later" form="{{ product_form_id }}">
          <span>{{ bs.send_later_label | escape }}</span>
        </label>
      {% endif %}
    </div>

    <input
      type="hidden"
      form="{{ product_form_id }}"
      name="properties[{{ status_name | strip | replace: '"', '' }}]"
      value="Pending review"
      data-rx-status
    >

    <div class="atelier-prescription-input__warning" data-rx-warning hidden>
      {{ bs.rx_required_message | escape }}
    </div>

    <div class="atelier-prescription-input__fields" data-rx-fields>
      <div class="atelier-prescription-input__row atelier-prescription-input__row--head">
        <span></span>
        <span>SPH</span>
        <span>CYL</span>
        <span>AXIS</span>
        <span>ADD</span>
      </div>

      {% for eye in 'OD,OS' | split: ',' %}
        <div class="atelier-prescription-input__row">
          <span class="atelier-prescription-input__eye">{{ eye }}</span>
          <label>
            <span class="visually-hidden">{{ eye }} SPH</span>
            <input type="text" inputmode="decimal" form="{{ product_form_id }}" name="properties[{{ eye }} SPH]" pattern="^-?\d{0,2}(\.\d{0,2})?$" placeholder="+/-0.00">
          </label>
          <label>
            <span class="visually-hidden">{{ eye }} CYL</span>
            <input type="text" inputmode="decimal" form="{{ product_form_id }}" name="properties[{{ eye }} CYL]" pattern="^-?\d{0,2}(\.\d{0,2})?$" placeholder="+/-0.00">
          </label>
          <label>
            <span class="visually-hidden">{{ eye }} AXIS</span>
            <input type="number" inputmode="numeric" min="1" max="180" form="{{ product_form_id }}" name="properties[{{ eye }} AXIS]" placeholder="1-180">
          </label>
          <label>
            <span class="visually-hidden">{{ eye }} ADD</span>
            <input type="text" inputmode="decimal" form="{{ product_form_id }}" name="properties[{{ eye }} ADD]" pattern="^\+?\d{0,2}(\.\d{0,2})?$" placeholder="+0.00">
          </label>
        </div>
      {% endfor %}

      <div class="atelier-prescription-input__pd">
        <label>
          <span>PD</span>
          <input
            type="text"
            inputmode="decimal"
            form="{{ product_form_id }}"
            name="properties[PD]"
            pattern="^\d{1,2}(\.\d{0,2})?$"
            placeholder="e.g. 63.0"
          >
        </label>
      </div>
    </div>
  </div>

  <script>
    (function () {
      const root = document.currentScript.previousElementSibling;
      if (!root) return;
      const formId = {{ product_form_id | json }};
      const form = document.getElementById(formId);
      if (!form) return;

      const warning = root.querySelector('[data-rx-warning]');
      const fieldsWrap = root.querySelector('[data-rx-fields]');
      const methodInputs = root.querySelectorAll('input[name^="properties[{{ method_name | strip | replace: '"', '' }}]"]');
      const statusInput = root.querySelector('[data-rx-status]');
      const rxLensListRaw = root.dataset.rxLensOptions || '';
      const rxLensList = rxLensListRaw.split('|').map((item) => item.trim().toLowerCase()).filter(Boolean);
      const lensPropertyKey = root.dataset.lensPropertyKey || 'Lens type';

      const lensSelect = form.querySelector(`select[name="properties[${lensPropertyKey}]"]`);
      const numericFields = fieldsWrap ? fieldsWrap.querySelectorAll('input') : [];

      function lensRequiresPrescription() {
        if (!lensSelect || !lensSelect.value) return false;
        return rxLensList.includes(lensSelect.value.trim().toLowerCase());
      }

      function activeMethod() {
        const selected = Array.from(methodInputs).find((input) => input.checked);
        return selected ? selected.value : 'Manual entry';
      }

      function updateUi() {
        const rxRequired = lensRequiresPrescription();
        const sendLater = activeMethod() === 'Send later';
        const showManualFields = rxRequired && !sendLater;

        if (warning) warning.hidden = !rxRequired;
        if (fieldsWrap) fieldsWrap.hidden = !showManualFields;
        if (statusInput) {
          statusInput.value = sendLater ? 'Send later' : (rxRequired ? 'Manual entry' : 'Not required');
        }
      }

      function validateField(field) {
        if (!field || field.disabled || field.offsetParent === null) return;
        if (field.validity.patternMismatch || field.validity.rangeOverflow || field.validity.rangeUnderflow) {
          field.setCustomValidity('Please use a valid prescription value.');
        } else {
          field.setCustomValidity('');
        }
      }

      if (lensSelect) {
        lensSelect.addEventListener('change', updateUi);
      }
      methodInputs.forEach((input) => input.addEventListener('change', updateUi));
      numericFields.forEach((field) => {
        field.addEventListener('input', () => validateField(field));
        field.addEventListener('blur', () => validateField(field));
      });

      updateUi();
    })();
  </script>

  {% stylesheet %}
    .atelier-prescription-input {
      display: grid;
      gap: 12px;
    }

    .atelier-prescription-input__heading {
      margin: 0;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
    }

    .atelier-prescription-input__description {
      margin: 0;
      font-size: 11px;
      line-height: 1.7;
      color: rgb(var(--color-foreground-rgb) / 0.6);
    }

    .atelier-prescription-input__method {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .atelier-prescription-input__method-option {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 10px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .atelier-prescription-input__warning {
      padding: 10px 12px;
      border: 1px solid rgb(var(--color-primary-rgb) / 0.28);
      background: rgb(var(--color-primary-rgb) / 0.08);
      font-size: 10px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .atelier-prescription-input__fields {
      display: grid;
      gap: 8px;
    }

    .atelier-prescription-input__row {
      display: grid;
      grid-template-columns: 44px repeat(4, minmax(0, 1fr));
      gap: 8px;
      align-items: center;
    }

    .atelier-prescription-input__row input {
      width: 100%;
      min-height: 40px;
      border-radius: 0;
    }

    .atelier-prescription-input__row--head span {
      font-size: 8px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgb(var(--color-foreground-rgb) / 0.6);
    }

    .atelier-prescription-input__eye {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .atelier-prescription-input__pd label {
      display: grid;
      gap: 6px;
      max-width: 180px;
    }

    .atelier-prescription-input__pd span {
      font-size: 8px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgb(var(--color-foreground-rgb) / 0.6);
    }

    @media screen and (max-width: 749px) {
      .atelier-prescription-input__row {
        grid-template-columns: 32px 1fr 1fr;
      }

      .atelier-prescription-input__row--head {
        display: none;
      }
    }
  {% endstylesheet %}
{% endif %}

{% schema %}
{
  "name": "Prescription input",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Prescription details"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Enter your prescription now or choose send later at checkout."
    },
    {
      "type": "textarea",
      "id": "rx_lens_options",
      "label": "Lens options that require prescription (one per line)",
      "default": "Single vision\nProgressive"
    },
    {
      "type": "text",
      "id": "lens_property_key",
      "label": "Lens line item property key",
      "default": "Lens type"
    },
    {
      "type": "text",
      "id": "method_property_key",
      "label": "Prescription method property key",
      "default": "Prescription method"
    },
    {
      "type": "text",
      "id": "status_property_key",
      "label": "Prescription status property key",
      "default": "Prescription status"
    },
    {
      "type": "text",
      "id": "manual_entry_label",
      "label": "Manual entry option label",
      "default": "Enter manually"
    },
    {
      "type": "checkbox",
      "id": "enable_send_later",
      "label": "Enable send-later option",
      "default": true
    },
    {
      "type": "text",
      "id": "send_later_label",
      "label": "Send-later option label",
      "default": "Send prescription later"
    },
    {
      "type": "text",
      "id": "rx_required_message",
      "label": "Message when selected lens requires prescription",
      "default": "This lens type needs prescription details."
    },
    {
      "type": "checkbox",
      "id": "disable_metafield_gate",
      "label": "Show even when product metafield is off (debug)",
      "default": false
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "Inherit color scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Prescription input"
    }
  ]
}
{% endschema %}
