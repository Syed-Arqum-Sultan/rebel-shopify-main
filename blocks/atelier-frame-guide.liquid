{%- liquid
  assign bs = block.settings
  assign dialog_id = 'FrameGuide-' | append: section.id | append: '-' | append: block.id
-%}

<div
  class="atelier-frame-guide spacing-style"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>
  <button
    type="button"
    class="button button-secondary atelier-frame-guide__trigger"
    aria-haspopup="dialog"
    aria-controls="{{ dialog_id }}"
  >
    {{ bs.trigger_label | escape }}
  </button>

  <dialog
    id="{{ dialog_id }}"
    class="atelier-frame-guide__dialog color-{{ settings.popover_color_scheme | default: 'scheme-1' }}"
    aria-labelledby="{{ dialog_id }}-title"
  >
    <div class="atelier-frame-guide__dialog-inner">
      <button
        type="button"
        class="atelier-frame-guide__close button-unstyled"
        aria-label="{{ 'accessibility.close_dialog' | t }}"
        data-close-dialog
      >
        <span class="svg-wrapper" aria-hidden="true">{{ 'icon-close.svg' | inline_asset_content }}</span>
      </button>
      {% if bs.heading != blank %}
        <h2 id="{{ dialog_id }}-title" class="atelier-frame-guide__title">
          {{ bs.heading | escape }}
        </h2>
      {% endif %}
      {% if bs.body != blank %}
        <div class="rte rte--inherit atelier-frame-guide__body">
          {{ bs.body }}
        </div>
      {% endif %}
    </div>
  </dialog>
</div>

<script>
  (function () {
    const root = document.currentScript.previousElementSibling;
    if (!root) return;
    const dialog = root.querySelector('dialog');
    const openBtn = root.querySelector('.atelier-frame-guide__trigger');
    const closeBtn = root.querySelector('[data-close-dialog]');
    if (!dialog || !openBtn) return;
    openBtn.addEventListener('click', () => {
      dialog.showModal();
    });
    closeBtn?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      const rect = dialog.getBoundingClientRect();
      const inDialog =
        rect.top <= e.clientY &&
        e.clientY <= rect.top + rect.height &&
        rect.left <= e.clientX &&
        e.clientX <= rect.left + rect.width;
      if (!inDialog) dialog.close();
    });
  })();
</script>

{% stylesheet %}
  .atelier-frame-guide__trigger {
    width: fit-content;
  }

  .atelier-frame-guide__dialog {
    max-width: min(36rem, 94vw);
    width: 100%;
    padding: 0;
    border: var(--style-border-width) solid var(--color-border);
    border-radius: var(--style-border-radius-popover);
    background: var(--color-background);
    color: var(--color-foreground);
    box-shadow: var(--shadow-popover);
  }

  .atelier-frame-guide__dialog::backdrop {
    background: rgb(0 0 0 / 45%);
  }

  .atelier-frame-guide__dialog-inner {
    position: relative;
    padding: var(--padding-2xl) var(--padding-xl);
  }

  .atelier-frame-guide__close {
    position: absolute;
    top: var(--padding-sm);
    right: var(--padding-sm);
    padding: var(--padding-xs);
    cursor: pointer;
    color: inherit;
  }

  .atelier-frame-guide__title {
    margin: 0 0 var(--padding-md);
    font-family: var(--font-heading--family);
    font-size: var(--font-h4--size);
  }

  .atelier-frame-guide__body {
    max-height: min(60vh, 28rem);
    overflow: auto;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Frame size guide",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "trigger_label",
      "label": "Button label",
      "default": "Frame size guide"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Popup heading",
      "default": "Find your fit"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Guide content",
      "default": "<p>Measure your favorite frames or use our chart: narrow (below 130mm), medium (130–139mm), wide (140mm+). Our opticians can help finalize lens height and bridge fit.</p>"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Frame size guide"
    }
  ]
}
{% endschema %}
